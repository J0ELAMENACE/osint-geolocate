console = Console()

# ─── EXIF ────────────────────────────────────────────────────────────────────

def dms_to_decimal(dms, ref):
    """Convert degrees/minutes/seconds tuple to decimal degrees."""
    try:
        d, m, s = dms
        # Handle IFDRational objects
        d = float(d)
        m = float(m)
        s = float(s)
        decimal = d + m / 60.0 + s / 3600.0
        if ref in ("S", "W"):
            decimal = -decimal
        return decimal
    except Exception:
        return None


def extract_exif(path: Path):
    """Return (lat, lon, timestamp) from EXIF or (None, None, None)."""
    try:
        img = Image.open(path)
        exif_data = img._getexif()
        if not exif_data:
            return None, None, None

        gps_info = {}
        timestamp = None

        for tag_id, value in exif_data.items():
            tag = TAGS.get(tag_id, tag_id)
            if tag == "GPSInfo":
                for gps_tag_id, gps_val in value.items():
                    gps_tag = GPSTAGS.get(gps_tag_id, gps_tag_id)
                    gps_info[gps_tag] = gps_val
            elif tag == "DateTime":
                try:
                    timestamp = datetime.strptime(value, "%Y:%m:%d %H:%M:%S")
                except Exception:
                    pass
            elif tag == "DateTimeOriginal":
                try:
                    timestamp = datetime.strptime(value, "%Y:%m:%d %H:%M:%S")
                except Exception:
                    pass

        if not gps_info:
            return None, None, timestamp

        lat = dms_to_decimal(
            gps_info.get("GPSLatitude"),
            gps_info.get("GPSLatitudeRef", "N"),
        )
        lon = dms_to_decimal(
            gps_info.get("GPSLongitude"),
            gps_info.get("GPSLongitudeRef", "E"),
        )

        return lat, lon, timestamp

    except Exception as e:
        console.print(f"[yellow]EXIF read error: {e}[/yellow]")
        return None, None, None


# ─── SOLAR ANALYSIS ──────────────────────────────────────────────────────────

def solar_analysis(lat: float, lon: float, timestamp: datetime):
    """Return a short note about solar consistency."""
    try:
        import ephem  # type: ignore

        obs = ephem.Observer()
        obs.lat = str(lat)
        obs.lon = str(lon)
        if timestamp.tzinfo is None:
            obs.date = timestamp.strftime("%Y/%m/%d %H:%M:%S")
        else:
            obs.date = timestamp.astimezone(timezone.utc).strftime("%Y/%m/%d %H:%M:%S")

        sun = ephem.Sun(obs)
        alt_deg = math.degrees(float(sun.alt))
        az_deg = math.degrees(float(sun.az))

        if alt_deg < 0:
            return f"Soleil sous l'horizon à cette heure ({alt_deg:.1f}°) — nuit probable"
        return f"Soleil à {alt_deg:.1f}° d'altitude, azimut {az_deg:.1f}°"

    except ImportError:
        return "Module ephem non disponible"
    except Exception as e:
        return f"Calcul impossible ({e})"


# ─── AI PROMPT ───────────────────────────────────────────────────────────────

VISION_PROMPT = """You are an expert OSINT geolocation analyst. Analyze this image and extract every geographic clue.

Respond ONLY with a JSON object — no markdown, no code fences, no preamble:

{
  "landmarks": [{"name": "...", "confidence": 0.0}],
  "language": "...",
  "architecture_style": "...",
  "vegetation": "...",
  "signage": "...",
  "flags_or_emblems": "...",
  "climate_zone": "...",
  "estimated_region": "...",
  "estimated_country": "...",
  "estimated_city": "...",
  "estimated_lat": null,
  "estimated_lon": null,
  "reasoning": "..."
}

Rules:
- Be precise about estimated_lat / estimated_lon (decimal degrees) when you have strong indicators.
- Set them to null if genuinely uncertain.
- confidence is 0.0 to 1.0.
- Keep all string values concise (one line each).
"""


def image_to_base64(path: Path) -> str:
    with open(path, "rb") as f:
        return base64.b64encode(f.read()).decode("utf-8")


def get_image_mime(path: Path) -> str:
    suffix = path.suffix.lower()
    return {
        ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
        ".png": "image/png", ".webp": "image/webp",
        ".gif": "image/gif",
    }.get(suffix, "image/jpeg")


# ─── OLLAMA ──────────────────────────────────────────────────────────────────

# Ordre de priorité : cloud vision models first (pas de GPU requis),
# puis fallback local si disponible.
# gemma4 en tête : vision + thinking + cloud, 5.6M pulls, excellente géo.
OLLAMA_PREFERRED = [
    "gemma4",           # vision + thinking + cloud  — défaut recommandé VM
    "kimi-k2.6",        # vision + thinking + cloud  — agentic, très récent
    "llama3.2-vision",  # local uniquement, GPU requis
    "llava",            # local uniquement, GPU requis
    "llava:13b",
    "minicpm-v",
    "moondream",
]

# Mots-clés de fallback pour détecter un modèle vision non listé
VISION_KEYWORDS = ["vision", "llava", "llama3.2", "moondream", "minicpm",
                   "gemma4", "kimi", "gemini"]

# Timeout plus long pour les modèles cloud Ollama (réseau + inférence distante)
OLLAMA_TIMEOUT = 180


def ollama_list_models():
    try:
        r = requests.get("http://localhost:11434/api/tags", timeout=5)
        r.raise_for_status()
        return [m["name"] for m in r.json().get("models", [])]
    except Exception:
        return []


def ollama_pick_vision_model(models):
    for preferred in OLLAMA_PREFERRED:
        for m in models:
            if preferred in m.lower():
                return m
    # Fallback: keyword scan
    for m in models:
        for kw in VISION_KEYWORDS:
            if kw in m.lower():
                return m
    return models[0] if models else None


def analyze_ollama(path: Path, model_override: str = None) -> dict:
    models = ollama_list_models()
    if not models:
        console.print("[red]Ollama non accessible sur localhost:11434[/red]")
        console.print("[dim]Lancez Ollama avec : ollama serve[/dim]")
        sys.exit(1)

    if model_override:
        model = model_override
    else:
        model = ollama_pick_vision_model(models)

    if not model:
        console.print("[red]Aucun modèle vision trouvé dans Ollama.[/red]")
        console.print(f"[dim]Modèles disponibles : {', '.join(models)}[/dim]")
        console.print("[dim]Installez gemma4 : ollama pull gemma4[/dim]")
        sys.exit(1)

    # Avertissement si le modèle n'est pas dans la liste préférée vision
    is_known_vision = any(kw in model.lower() for kw in VISION_KEYWORDS)
    if not is_known_vision:
        console.print(f"[yellow]⚠ '{model}' n'est pas un modèle vision connu — les résultats peuvent être dégradés.[/yellow]")

    console.print(f"[dim]Modèle Ollama : {model}[/dim]")

    b64 = image_to_base64(path)
    payload = {
        "model": model,
        "prompt": VISION_PROMPT,
        "images": [b64],
        "stream": False,
        "options": {"temperature": 0.1},
    }

    try:
        r = requests.post(
            "http://localhost:11434/api/generate",
            json=payload,
            timeout=OLLAMA_TIMEOUT,
        )
        r.raise_for_status()
        raw = r.json().get("response", "")
        return parse_ai_response(raw)
    except requests.exceptions.Timeout:
        console.print("[red]Timeout Ollama (>120s). Modèle trop lent.[/red]")
        sys.exit(1)
    except Exception as e:
        console.print(f"[red]Erreur Ollama : {e}[/red]")
        sys.exit(1)


# ─── GEMINI ──────────────────────────────────────────────────────────────────

def analyze_gemini(path: Path, api_key: str) -> dict:
    b64 = image_to_base64(path)
    mime = get_image_mime(path)

    url = (
        "https://generativelanguage.googleapis.com/v1beta/models/"
        f"gemini-2.0-flash:generateContent?key={api_key}"
    )

    payload = {
        "contents": [{
            "parts": [
                {"text": VISION_PROMPT},
                {"inline_data": {"mime_type": mime, "data": b64}},
            ]
        }],
        "generationConfig": {"temperature": 0.1, "maxOutputTokens": 1024},
    }

    try:
        r = requests.post(url, json=payload, timeout=60)
        r.raise_for_status()
        data = r.json()
        raw = data["candidates"][0]["content"]["parts"][0]["text"]
        return parse_ai_response(raw)
    except requests.exceptions.HTTPError as e:
        if e.response.status_code == 400:
            console.print("[red]Clé Gemini invalide ou quota dépassé.[/red]")
        elif e.response.status_code == 403:
            console.print("[red]Accès refusé — vérifiez votre clé API Gemini.[/red]")
        else:
            console.print(f"[red]Erreur HTTP Gemini {e.response.status_code}[/red]")
        sys.exit(1)
    except Exception as e:
        console.print(f"[red]Erreur Gemini : {e}[/red]")
        sys.exit(1)


# ─── RESPONSE PARSER ─────────────────────────────────────────────────────────

def parse_ai_response(raw: str) -> dict:
    """Extract JSON from AI response, handling markdown fences."""
    # Strip markdown code fences
    clean = re.sub(r"```(?:json)?", "", raw).strip()
    # Find first { ... } block
    match = re.search(r"\{.*\}", clean, re.DOTALL)
    if match:
        try:
            return json.loads(match.group())
        except json.JSONDecodeError:
            pass

    # Fallback: try to parse the whole string
    try:
        return json.loads(clean)
    except json.JSONDecodeError:
        # Return raw reasoning as-is
        return {"reasoning": raw, "estimated_lat": None, "estimated_lon": None}


# ─── COORDINATE EXTRACTION ───────────────────────────────────────────────────

def coords_from_analysis(analysis: dict):
    """Try to get (lat, lon) from the AI analysis dict."""
    lat = analysis.get("estimated_lat")
    lon = analysis.get("estimated_lon")
    try:
        if lat is not None and lon is not None:
            return float(lat), float(lon)
    except (ValueError, TypeError):
        pass

    # Try parsing from reasoning text
    reasoning = analysis.get("reasoning", "")
    pattern = r"(-?\d{1,3}\.\d+)[°\s,]+[NS]?\s*[,/]\s*(-?\d{1,3}\.\d+)"
    m = re.search(pattern, reasoning)
    if m:
        return float(m.group(1)), float(m.group(2))

    return None, None


# ─── RICH OUTPUT ─────────────────────────────────────────────────────────────

def tag(label: str, color: str = "cyan") -> Text:
    t = Text()
    t.append(f"[{label}]", style=f"bold {color}")
    return t


def print_section(label: str, content: str, color: str = "cyan"):
    prefix = Text()
    prefix.append(f"[{label:<7}]", style=f"bold {color}")
    prefix.append(f"  {content}")
    console.print(prefix)


def print_header(image_path: Path):
    console.print()
    console.print(
        Panel(
            f"[bold white]OSINT-GEOLOCATE[/bold white]  [dim]{image_path.name}[/dim]",
            box=box.DOUBLE_EDGE,
            style="bright_blue",
            padding=(0, 2),
        )
    )
    console.print()


def print_analysis(analysis: dict):
    landmarks = analysis.get("landmarks", [])
    if landmarks:
        top = sorted(landmarks, key=lambda x: x.get("confidence", 0), reverse=True)[:3]
        lm_str = ", ".join(
            f"{l['name']} ({int(l.get('confidence', 0) * 100)}%)" for l in top
        )
        print_section("VISUAL", f"Landmarks  : {lm_str}", "green")
    else:
        print_section("VISUAL", "Aucun landmark identifié", "green")

    for field, label in [
        ("language", "Langue      "),
        ("architecture_style", "Architecture"),
        ("vegetation", "Végétation  "),
        ("signage", "Signalisation"),
        ("flags_or_emblems", "Drapeaux    "),
        ("climate_zone", "Climat      "),
    ]:
        val = analysis.get(field)
        if val and val.lower() not in ("none", "unknown", "n/a", "null", ""):
            print_section("VISUAL", f"{label} : {val}", "green")

    reasoning = analysis.get("reasoning")
    if reasoning and len(reasoning) < 300:
        print_section("VISUAL", f"Raisonnement: {reasoning}", "dim green")


# ─── MAIN ────────────────────────────────────────────────────────────────────

@click.command()
@click.argument("image", type=click.Path(exists=True, readable=True))
@click.option("--cloud", is_flag=True, help="Use Gemini 2.0 Flash instead of Ollama")
@click.option("--gemini-key", envvar="GEMINI_API_KEY", default=None,
              help="Gemini API key (or set GEMINI_API_KEY env var)")
@click.option("--model", default=None,
              help="Force a specific Ollama model (ex: gemma4, kimi-k2.6)")
@click.option("--no-solar", is_flag=True, default=False, help="Skip solar calculation")
def main(image, cloud, gemini_key, model, no_solar):
    """
    OSINT image geolocation — EXIF + AI vision + solar analysis.

    Défaut : Ollama avec gemma4 (cloud, vision+thinking, no GPU requis).
    Fallback : Gemini 2.0 Flash avec --cloud.

    \b
    Examples:
      osint-geolocate photo.jpg
      osint-geolocate photo.jpg --model kimi-k2.6
      osint-geolocate photo.jpg --cloud --gemini-key YOUR_KEY
      GEMINI_API_KEY=xxx osint-geolocate photo.jpg --cloud
    """
    path = Path(image)
    print_header(path)

    # ── STEP 1: EXIF ──────────────────────────────────────────────────────
    lat, lon, timestamp = extract_exif(path)

    if lat is not None and lon is not None:
        print_section("EXIF", f"GPS trouvé : {lat:.6f}° N, {lon:.6f}° E", "bright_cyan")
        if timestamp:
            print_section("EXIF", f"Date/heure : {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "bright_cyan")
        console.print()
        _print_result(lat, lon, "EXIF GPS")
        return
    else:
        print_section("EXIF", "Aucune donnée GPS trouvée", "yellow")
        if timestamp:
            print_section("EXIF", f"Timestamp  : {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "dim yellow")

    console.print()

    # ── STEP 2: AI VISION ─────────────────────────────────────────────────
    if cloud:
        if not gemini_key:
            console.print(
                "[red]--cloud nécessite une clé Gemini.[/red]\n"
                "[dim]Passez --gemini-key KEY ou exportez GEMINI_API_KEY=...[/dim]\n"
                "[dim]Clé gratuite sur : https://aistudio.google.com/apikey[/dim]"
            )
            sys.exit(1)
        console.print("[dim]Envoi à Gemini 2.0 Flash...[/dim]")
        analysis = analyze_gemini(path, gemini_key)
    else:
        console.print("[dim]Analyse via Ollama (gemma4 cloud par défaut)...[/dim]")
        analysis = analyze_ollama(path, model_override=model)

    print_analysis(analysis)
    console.print()

    ai_lat, ai_lon = coords_from_analysis(analysis)

    # ── STEP 3: SOLAR ─────────────────────────────────────────────────────
    if not no_solar and timestamp and ai_lat is not None:
        solar_note = solar_analysis(ai_lat, ai_lon, timestamp)
        print_section("SOLAR", solar_note, "magenta")
        console.print()
    elif not no_solar:
        print_section("SOLAR", "Timestamp ou coordonnées manquants — calcul ignoré", "dim magenta")
        console.print()

    # ── STEP 4: RESULT ────────────────────────────────────────────────────
    city = analysis.get("estimated_city") or ""
    country = analysis.get("estimated_country") or ""
    region = analysis.get("estimated_region") or ""

    location_str = ", ".join(filter(None, [city, country or region]))

    if ai_lat is not None and ai_lon is not None:
        _print_result(ai_lat, ai_lon, location_str or "Estimation IA")
    else:
        console.print(
            Panel(
                "[yellow]Coordonnées insuffisamment précises pour générer un lien.[/yellow]\n"
                f"[dim]Région estimée : {location_str or 'Inconnue'}[/dim]",
                box=box.ROUNDED,
                style="yellow",
            )
        )

    console.print()


def _print_result(lat: float, lon: float, label: str):
    maps_url = f"https://maps.google.com/?q={lat:.6f},{lon:.6f}"

    console.print(
        Panel(
            f"[bold green]→ {label}[/bold green]\n"
            f"[white]   {lat:.4f}° {'N' if lat >= 0 else 'S'},  "
            f"{abs(lon):.4f}° {'E' if lon >= 0 else 'W'}[/white]",
            box=box.ROUNDED,
            style="green",
            padding=(0, 2),
        )
    )
    console.print()
    prefix = Text()
    prefix.append("[MAPS]  ", style="bold bright_blue")
    prefix.append(maps_url, style="bright_blue underline")
    console.print(prefix)
    console.print()


if __name__ == "__main__":
    main()
