# ─── OLLAMA ──────────────────────────────────────────────────────────────────

DEFAULT_MODEL  = "gemma4:31b-cloud"
OLLAMA_TIMEOUT = 300  # 3 passes x modèle 31b cloud

def image_to_b64(path):
    with open(path, "rb") as f:
        return base64.b64encode(f.read()).decode()

def get_mime(path):
    return {".jpg":"image/jpeg",".jpeg":"image/jpeg",".png":"image/png",
            ".webp":"image/webp",".gif":"image/gif"}.get(Path(path).suffix.lower(),"image/jpeg")

def ollama_ping():
    try:
        r = requests.get("http://localhost:11434/api/tags", timeout=5)
        r.raise_for_status()
        return True
    except: return False

def ollama_call(model, prompt, b64=None):
    payload = {"model": model, "prompt": prompt, "stream": False, "options": {"temperature": 0.1}}
    if b64: payload["images"] = [b64]
    r = requests.post("http://localhost:11434/api/generate", json=payload, timeout=OLLAMA_TIMEOUT)
    r.raise_for_status()
    return r.json().get("response", "")

def analyze_ollama(path, model_override=None):
    if not ollama_ping():
        console.print("[red]Ollama non accessible sur localhost:11434[/red]")
        console.print("[dim]Lancez : ollama serve[/dim]")
        sys.exit(1)
    model = model_override or DEFAULT_MODEL
    console.print(f"[dim]Modèle : {model}[/dim]")
    b64 = image_to_b64(path)

    console.print("[dim cyan]Passe 1/3 — description visuelle générale...[/dim cyan]")
    raw0  = ollama_call(model, PROMPT_PASS0, b64)
    scene = parse_response(raw0)

    console.print("[dim cyan]Passe 2/3 — extraction des indices géographiques...[/dim cyan]")
    desc  = scene.get("description", json.dumps(scene, ensure_ascii=False))
    raw1  = ollama_call(model, PROMPT_PASS1.format(description=desc), b64)
    clues = parse_response(raw1)

    console.print("[dim cyan]Passe 3/3 — raisonnement géographique...[/dim cyan]")
    prompt2 = PROMPT_PASS2.format(clues=json.dumps({**scene, **clues}, ensure_ascii=False, indent=2))
    raw2    = ollama_call(model, prompt2)
    geo     = parse_response(raw2)
    return {**scene, **clues, **geo, "_scene": scene}

# ─── GEMINI ──────────────────────────────────────────────────────────────────

def gemini_call(api_key, prompt, b64=None, mime="image/jpeg"):
    url   = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={api_key}"
    parts = [{"text": prompt}]
    if b64: parts.append({"inline_data": {"mime_type": mime, "data": b64}})
    r = requests.post(url, json={"contents":[{"parts":parts}],
        "generationConfig":{"temperature":0.1,"maxOutputTokens":2048}}, timeout=60)
    r.raise_for_status()
    return r.json()["candidates"][0]["content"]["parts"][0]["text"]

def analyze_gemini(path, api_key):
    b64, mime = image_to_b64(path), get_mime(path)

    console.print("[dim cyan]Passe 1/3 — description visuelle générale (Gemini)...[/dim cyan]")
    try:
        raw0  = gemini_call(api_key, PROMPT_PASS0, b64, mime)
        scene = parse_response(raw0)
    except requests.exceptions.HTTPError as e:
        console.print(f"[red]Gemini error {e.response.status_code}[/red]")
        sys.exit(1)

    console.print("[dim cyan]Passe 2/3 — extraction des indices géographiques (Gemini)...[/dim cyan]")
    desc  = scene.get("description", json.dumps(scene, ensure_ascii=False))
    try:
        raw1  = gemini_call(api_key, PROMPT_PASS1.format(description=desc), b64, mime)
        clues = parse_response(raw1)
    except Exception as e:
        console.print(f"[yellow]Passe 2 échouée : {e}[/yellow]")
        return scene

    console.print("[dim cyan]Passe 3/3 — raisonnement géographique (Gemini)...[/dim cyan]")
    prompt2 = PROMPT_PASS2.format(clues=json.dumps({**scene, **clues}, ensure_ascii=False, indent=2))
    try:
        raw2 = gemini_call(api_key, prompt2)
        geo  = parse_response(raw2)
        return {**scene, **clues, **geo, "_scene": scene}
    except Exception as e:
        console.print(f"[yellow]Passe 3 échouée : {e}[/yellow]")
        return {**scene, **clues}

# ─── PARSER ──────────────────────────────────────────────────────────────────

def parse_response(raw):
    clean = re.sub(r"```(?:json)?", "", raw).strip()
    m = re.search(r"\{.*\}", clean, re.DOTALL)
    if m:
        try: return json.loads(m.group())
        except: pass
    try: return json.loads(clean)
    except: return {"reasoning": raw, "estimated_lat": None, "estimated_lon": None}

def coords_from(analysis):
    lat, lon = analysis.get("estimated_lat"), analysis.get("estimated_lon")
    try:
        if lat is not None and lon is not None:
            return float(lat), float(lon)
    except: pass
    m = re.search(r"(-?\d{1,3}\.\d+)[°\s,]+[NS]?\s*[,/]\s*(-?\d{1,3}\.\d+)",
                  analysis.get("reasoning",""))
    if m: return float(m.group(1)), float(m.group(2))
    return None, None

# ─── OUTPUT ──────────────────────────────────────────────────────────────────

def ps(label, content, color="cyan"):
    t = Text()
    t.append(f"[{label:<8}]", style=f"bold {color}")
    t.append(f"  {content}")
    console.print(t)

def nonempty(v):
    return v and str(v).lower().strip() not in ("", "none", "null", "n/a", "unknown")

def print_clues(a):
    # ── Passe 0 : description générale ──────────────────────────────────
    scene = a.get("_scene", {})
    desc  = scene.get("description") or a.get("description", "")
    if desc and len(desc) > 10:
        console.print(Panel(
            f"[white]{desc}[/white]",
            title="[bold dim]DESCRIPTION VISUELLE[/bold dim]",
            box=box.SIMPLE, style="dim", padding=(0, 2)
        ))
        console.print()

    for key, label in [
        ("scene_type",  "Type de scène"),
        ("setting",     "Environnement"),
        ("time_of_day", "Heure approx."),
        ("season",      "Saison        "),
        ("weather",     "Météo         "),
        ("perspective", "Perspective   "),
    ]:
        v = scene.get(key) or a.get(key, "")
        if nonempty(v):
            ps("SCÈNE", f"{label} : {v}", "dim white")

    notables = scene.get("notable_elements") or a.get("notable_elements", [])
    if notables:
        ps("SCÈNE", f"Éléments     : {', '.join(notables[:6])}", "dim white")

    console.print()

    # ── Passes 1 & 2 : indices géo ──────────────────────────────────────
    lms = a.get("landmarks", [])
    if lms:
        top = sorted(lms, key=lambda x: x.get("confidence",0), reverse=True)[:3]
        ps("VISUAL", "Landmarks    : " + ", ".join(f"{l['name']} ({int(l.get('confidence',0)*100)}%)" for l in top), "green")

    for key, label in [
        ("text_visible",              "Texte visible"),
        ("language_script",           "Langue/Script"),
        ("flags_emblems_coats_of_arms","Drapeaux/Arms"),
        ("vehicles",                  "Véhicules    "),
        ("cultural_clues",            "Culturel     "),
        ("vegetation",                "Végétation   "),
        ("climate_clues",             "Climat       "),
        ("sky_and_light",             "Lumière/Ombre"),
    ]:
        v = a.get(key, "")
        if nonempty(v):
            ps("VISUAL", f"{label} : {v}", "green")

    arch = a.get("architecture", {})
    if isinstance(arch, dict):
        parts = [f"{k}: {v}" for k, v in arch.items() if nonempty(v)]
        if parts: ps("VISUAL", "Architecture : " + " | ".join(parts), "green")

    infra = a.get("infrastructure", {})
    if isinstance(infra, dict):
        parts = [f"{k}: {v}" for k, v in infra.items() if nonempty(v)]
        if parts: ps("VISUAL", "Infra        : " + " | ".join(parts[:5]), "green")

    key_clues = a.get("key_clues_used", [])
    if key_clues:
        ps("REASON", "Indices clés : " + ", ".join(key_clues[:5]), "cyan")

    conf = a.get("confidence_level", "")
    if conf:
        color = {"high": "bright_green", "medium": "yellow", "low": "red"}.get(conf, "white")
        ps("REASON", f"Confiance    : {conf.upper()}", color)

    alts = a.get("alternative_locations", [])
    if alts:
        ps("REASON", "Alternatives : " + " | ".join(alts[:3]), "dim cyan")

    reason = a.get("reasoning", "")
    if reason and len(reason) < 500:
        ps("REASON", f"Analyse      : {reason}", "dim cyan")

def print_result(lat, lon, label, source=""):
    maps_url   = f"https://maps.google.com/?q={lat:.6f},{lon:.6f}"
    osm_url    = f"https://www.openstreetmap.org/?mlat={lat:.6f}&mlon={lon:.6f}&zoom=15"
    yandex_url = "https://yandex.com/images/search?rpt=imageview"

    src_str = f"  [dim]({source})[/dim]" if source else ""
    console.print(Panel(
        f"[bold green]→ {label}[/bold green]{src_str}\n"
        f"[white]   {abs(lat):.5f}° {'N' if lat>=0 else 'S'},  {abs(lon):.5f}° {'E' if lon>=0 else 'W'}[/white]",
        box=box.ROUNDED, style="green", padding=(0,2)
    ))
    console.print()
    for lbl, url, color in [("MAPS   ", maps_url,"bright_blue"),("OSM    ",osm_url,"bright_cyan"),("YANDEX ",yandex_url,"yellow")]:
        t = Text()
        t.append(f"[{lbl}]  ", style=f"bold {color}")
        t.append(url, style=f"{color} underline")
        console.print(t)
    console.print()
    console.print("[dim]  Yandex → glisser-déposer la photo pour reverse image search[/dim]")
    console.print()

# ─── CLI ─────────────────────────────────────────────────────────────────────

@click.command()
@click.argument("image", type=click.Path(exists=True, readable=True))


@click.option("--model", default=None, help="Forcer un modèle Ollama (défaut: gemma4:31b-cloud)")
@click.option("--no-solar",   is_flag=True, default=False, help="Désactiver calcul solaire")
@click.option("--no-geocode", is_flag=True, default=False, help="Désactiver Nominatim")
def main(image, model, no_solar, no_geocode):
    """
    OSINT image geolocation v2 — EXIF + AI 3-pass + Nominatim + solar.

    Moteur : Ollama + gemma4:31b-cloud (aucun GPU requis).

    \b
    Exemples:
      osint-geolocate photo.jpg
      osint-geolocate photo.jpg --model gemma4:27b-cloud
      osint-geolocate photo.jpg --no-solar
    """
    path = Path(image)
    console.print()
    console.print(Panel(
        f"[bold white]OSINT-GEOLOCATE v2[/bold white]  [dim]{path.name}[/dim]",
        box=box.DOUBLE_EDGE, style="bright_blue", padding=(0,2)
    ))
    console.print()

    # 1. EXIF
    lat, lon, timestamp = extract_exif(path)
    if lat is not None and lon is not None:
        ps("EXIF", f"GPS trouvé : {lat:.6f}°, {lon:.6f}°", "bright_cyan")
        if timestamp: ps("EXIF", f"Timestamp  : {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "bright_cyan")
        console.print()
        print_result(lat, lon, "Coordonnées EXIF", "GPS")
        return
    ps("EXIF", "Aucune donnée GPS", "yellow")
    if timestamp: ps("EXIF", f"Timestamp  : {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "dim yellow")
    console.print()

    # 2. AI 3-pass — Ollama gemma4:31b-cloud
    analysis = analyze_ollama(path, model_override=model)

    console.print()
    print_clues(analysis)
    console.print()

    ai_lat, ai_lon = coords_from(analysis)

    # 3. Nominatim fallback
    nom_lat, nom_lon, nom_name = None, None, None
    if not no_geocode and (ai_lat is None or ai_lon is None):
        query = build_geocode_query(analysis)
        if query:
            console.print(f"[dim]Géocodage Nominatim : \"{query}\"...[/dim]")
            nom_lat, nom_lon, nom_name = nominatim_geocode(query)
            if nom_lat:
                ps("GEOCODE", f"Résultat    : {nom_name}", "bright_magenta")
                ps("GEOCODE", f"Coordonnées : {nom_lat:.5f}°, {nom_lon:.5f}°", "bright_magenta")
                console.print()

    final_lat = ai_lat if ai_lat is not None else nom_lat
    final_lon = ai_lon if ai_lon is not None else nom_lon
    source    = "IA" if ai_lat is not None else ("Nominatim" if nom_lat else "")

    # 4. Solar
    if not no_solar and timestamp and final_lat is not None:
        ps("SOLAR", solar_analysis(final_lat, final_lon, timestamp), "magenta")
        console.print()

    # 5. Result
    city    = analysis.get("estimated_city") or ""
    country = analysis.get("estimated_country") or ""
    region  = analysis.get("estimated_region") or ""
    label   = ", ".join(filter(None, [city, country or region])) or "Estimation IA"

    if final_lat is not None and final_lon is not None:
        print_result(final_lat, final_lon, label, source)
    else:
        console.print(Panel(
            "[yellow]Coordonnées non déterminées.[/yellow]\n"
            f"[dim]Région estimée : {label or 'Inconnue'}[/dim]\n\n"
            "[white]→ Reverse image search :[/white]\n"
            "[yellow underline]https://yandex.com/images/search?rpt=imageview[/yellow underline]",
            box=box.ROUNDED, style="yellow"
        ))
        console.print()

if __name__ == "__main__":
    main()
