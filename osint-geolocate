def run_pipeline(path, picarta_key=None, no_search=False):
    b64 = image_to_b64(path)
    ocr_result, geo_result, reasoning_result = {}, {}, {}
    picarta_candidates = []
    if not ollama_ping():
        console.print("[red]Ollama non accessible sur localhost:11434[/red]")
        sys.exit(1)

    # Picarta
    if picarta_key:
        console.print(Rule("[dim]Picarta AI[/dim]", style="dim"))
        picarta_candidates = picarta_geolocate(path, picarta_key, top_k=5)
        # Si résultats faibles, relancer avec hint France
        if not picarta_candidates or all(c["confidence"] < 0.3 for c in picarta_candidates):
            console.print("[dim]Résultats faibles — relance avec hint France...[/dim]")
            picarta_candidates = picarta_geolocate(path, picarta_key, top_k=5, country_code="FR")
        if picarta_candidates:
            best = picarta_candidates[0]
            conf_pct = int(best["confidence"] * 100) if best["confidence"] <= 1 else int(best["confidence"])
            ps("PICARTA", f"Top 1 : {best.get('city','')}, {best.get('country','')} ({conf_pct}%)", "bright_green")
            ps("PICARTA", f"Coords : {best['lat']:.5f}, {best['lon']:.5f}", "bright_green")
            for i, c in enumerate(picarta_candidates[1:], 2):
                c2 = int(c["confidence"] * 100) if c["confidence"] <= 1 else int(c["confidence"])
                ps("PICARTA", f"Top {i} : {c.get('city','')}, {c.get('country','')} ({c2}%)", "dim green")
        else:
            ps("PICARTA", "Aucun resultat", "yellow")
        console.print()
    else:
        console.print("[dim]Picarta desactive -- ajoutez --picarta-key (gratuit : picarta.ai)[/dim]")
        console.print()

    # Passe OCR (qwen3.5)
    console.print(Rule(f"[dim]Passe 1/3 -- OCR ({MODEL_OCR})[/dim]", style="dim"))
    try:
        raw = ollama_call(MODEL_OCR, PROMPT_OCR, b64)
        ocr_result = parse_response(raw)
        txt = ocr_result.get("all_text_visible", "")
        codes = ocr_result.get("codes_numbers", [])
        if txt and txt.lower() not in ("none", "nothing", ""):
            ps("OCR", f"Texte  : {txt[:200]}", "bright_yellow")
        if codes:
            ps("OCR", f"Codes  : {', '.join(str(c) for c in codes[:10])}", "bright_yellow")
        lang = ocr_result.get("language_of_text", "")
        if lang and lang.lower() not in ("none", "unknown", ""):
            ps("OCR", f"Langue : {lang}", "bright_yellow")
        console.print("[dim]OK Passe OCR[/dim]")
    except Exception as e:
        console.print(f"[yellow]Passe OCR : {e.__class__.__name__}[/yellow]")
    console.print()

    # Passe GEO (gemma4)
    console.print(Rule(f"[dim]Passe 2/3 -- Indices geo ({MODEL_GEO})[/dim]", style="dim"))
    try:
        ctx = json.dumps(ocr_result, ensure_ascii=False)[:1500]
        raw = ollama_call(MODEL_GEO, PROMPT_GEO.replace("{context}", ctx), b64)
        geo_result = parse_response(raw)
        lms = geo_result.get("landmarks", [])
        if lms:
            top = sorted(lms, key=lambda x: x.get("confidence", 0), reverse=True)[:3]
            ps("GEO", "Landmarks : " + ", ".join(f"{l['name']} ({int(l.get('confidence',0)*100)}%)" for l in top), "green")
        infra = geo_result.get("infrastructure", {})
        if isinstance(infra, dict):
            for k, lbl in [("pavement_color","Trottoir"), ("license_plates","Plaques")]:
                v = infra.get(k, "")
                if v and v.lower() not in ("none","unknown",""): ps("GEO", f"{lbl} : {v}", "green")
        arch = geo_result.get("architecture", {})
        if isinstance(arch, dict) and arch.get("style","").lower() not in ("none","unknown",""):
            ps("GEO", f"Archi : {arch['style']}", "green")
        flags = geo_result.get("flags_emblems", "")
        if flags and flags.lower() not in ("none","unknown",""): ps("GEO", f"Drapeaux : {flags}", "bright_green")
        ec = geo_result.get("estimated_city","")
        ey = geo_result.get("estimated_country","")
        if ec or ey: ps("GEO", f"Estimation : {ec}, {ey}", "bright_green")
        console.print("[dim]OK Passe GEO[/dim]")
    except Exception as e:
        console.print(f"[yellow]Passe GEO : {e.__class__.__name__}[/yellow]")
    console.print()

    # Recherche web DDG
    web_results = []
    if DDG_AVAILABLE and not no_search:
        console.print(Rule("[dim]Recherche web DDG[/dim]", style="dim"))
        codes = ocr_result.get("codes_numbers", [])
        txt_v = ocr_result.get("all_text_visible", "")
        all_codes = list(set([str(c) for c in codes] + re.findall(r'[A-Z0-9]{6,}', txt_v.upper())))
        for code in all_codes[:2]:
            console.print(f'[dim]DDG : "{code}"...[/dim]')
            hits = web_search(f'"{code}" France ville localisation', max_results=3)
            if hits:
                web_results.append({"query": code, "hits": [{"title": h.get("title",""), "snippet": h.get("body","")} for h in hits]})
            time.sleep(0.5)
        city = geo_result.get("estimated_city","") or ""
        country = geo_result.get("estimated_country","") or ""
        if city and country:
            q = f"{city} {country} geographie localisation"
            hits = web_search(q, max_results=3)
            if hits:
                web_results.append({"query": q, "hits": [{"title": h.get("title",""), "snippet": h.get("body","")} for h in hits]})
        console.print()

    # Nominatim
    nom_lat, nom_lon = None, None
    city = geo_result.get("estimated_city","") or ""
    country = geo_result.get("estimated_country","") or ""
    skip_nom = city.lower() in ("unknown","") and country.lower() in ("unknown","")
    if (city or country) and not skip_nom:
        q = f"{city}, {country}".strip(", ")
        console.print(f'[dim]Nominatim : "{q}"...[/dim]')
        nom_lat, nom_lon, nom_name = nominatim_geocode(q)
        if nom_lat:
            ps("NOMINATIM", f"{(nom_name or q)[:80]}", "magenta")
            ps("NOMINATIM", f"{nom_lat:.5f}, {nom_lon:.5f}", "magenta")
        console.print()

    # Passe RAISONNEMENT (kimi)
    console.print(Rule(f"[dim]Passe 3/3 -- Raisonnement ({MODEL_REAS})[/dim]", style="dim"))
    try:
        pic_str = json.dumps(picarta_candidates[:3], ensure_ascii=False) if picarta_candidates else "Aucun"
        web_str = json.dumps(web_results, ensure_ascii=False)[:2000] if web_results else "Aucun"
        ocr_str = json.dumps({k:v for k,v in ocr_result.items()
                               if k in ("all_text_visible","codes_numbers","language_of_text","description")},
                              ensure_ascii=False)
        geo_str = json.dumps({k:v for k,v in geo_result.items()
                               if k in ("landmarks","architecture","infrastructure","flags_emblems",
                                        "estimated_country","estimated_city","estimated_region","cultural_clues")},
                              ensure_ascii=False)
        prompt_r = (PROMPT_REASONING
                    .replace("{ocr}", ocr_str)
                    .replace("{geo}", geo_str)
                    .replace("{picarta}", pic_str)
                    .replace("{web}", web_str))
        raw = ollama_call(MODEL_REAS, prompt_r, timeout=360)
        reasoning_result = parse_response(raw)
        conf = reasoning_result.get("confidence","")
        color = {"high":"bright_green","medium":"yellow","low":"red"}.get(conf,"white")
        ps("FINAL", f"Confiance : {conf.upper() if conf else '?'}", color)
        key_ev = reasoning_result.get("key_evidence",[])
        if key_ev: ps("FINAL", f"Preuves   : {', '.join(str(e) for e in key_ev[:4])}", "cyan")
        reason = reasoning_result.get("reasoning","")
        if reason and len(reason) < 400: ps("FINAL", f"Analyse   : {reason}", "dim cyan")
        console.print("[dim]OK Raisonnement[/dim]")
    except Exception as e:
        console.print(f"[yellow]Raisonnement : {e.__class__.__name__}[/yellow]")
    console.print()

    return ocr_result, geo_result, reasoning_result, picarta_candidates, nom_lat, nom_lon

def best_coords(reasoning, geo, picarta_candidates, nom_lat, nom_lon):
    try:
        lat, lon = reasoning.get("final_lat"), reasoning.get("final_lon")
        if lat and lon: return float(lat), float(lon), "raisonnement IA"
    except: pass
    try:
        lat, lon = geo.get("estimated_lat"), geo.get("estimated_lon")
        if lat and lon: return float(lat), float(lon), "gemma4"
    except: pass
    for c in picarta_candidates:
        conf = c.get("confidence", 0)
        conf_val = conf if conf > 1 else conf * 100
        if conf_val > 60 and c.get("lat") and c.get("lon"):
            return float(c["lat"]), float(c["lon"]), f"Picarta ({int(conf_val)}%)"
    if nom_lat and nom_lon: return nom_lat, nom_lon, "Nominatim"
    if picarta_candidates and picarta_candidates[0].get("lat"):
        c = picarta_candidates[0]
        return float(c["lat"]), float(c["lon"]), "Picarta"
    return None, None, ""

def print_result(lat, lon, label, source="", alternatives=None):
    maps_url = f"https://maps.google.com/?q={lat:.6f},{lon:.6f}"
    osm_url  = f"https://www.openstreetmap.org/?mlat={lat:.6f}&mlon={lon:.6f}&zoom=16"
    sv_url   = f"https://www.google.com/maps/@?api=1&map_action=pano&viewpoint={lat:.6f},{lon:.6f}"
    yandex   = "https://yandex.com/images/search?rpt=imageview"
    src = f"  [dim]({source})[/dim]" if source else ""
    console.print(Panel(
        f"[bold bright_green]-> {label}[/bold bright_green]{src}\n"
        f"[white]   {abs(lat):.5f} {'N' if lat>=0 else 'S'},  {abs(lon):.5f} {'E' if lon>=0 else 'W'}[/white]",
        box=box.DOUBLE_EDGE, style="bright_green", padding=(0,2)
    ))
    console.print()
    for lbl, url, color in [
        ("MAPS       ", maps_url, "bright_blue"),
        ("OSM        ", osm_url,  "bright_cyan"),
        ("STREET VIEW", sv_url,   "bright_green"),
        ("YANDEX     ", yandex,   "yellow"),
    ]:
        t = Text()
        t.append(f"[{lbl}]  ", style=f"bold {color}")
        t.append(url, style=f"{color} underline")
        console.print(t)
    console.print()
    if alternatives:
        console.print(Rule("[dim]Positions alternatives[/dim]", style="dim"))
        for i, a in enumerate(alternatives[:5], 1):
            alat, alon = a.get("lat"), a.get("lon")
            alabel = a.get("label") or f"{a.get('city','')}, {a.get('country','')}".strip(", ")
            reason = a.get("reason") or a.get("evidence","")
            console.print(f"  [bold cyan][{i}][/bold cyan] {alabel}")
            if reason: console.print(f"     [dim]{str(reason)[:100]}[/dim]")
            if alat and alon:
                try:
                    console.print(f"     [dim blue underline]https://maps.google.com/?q={float(alat):.5f},{float(alon):.5f}[/dim blue underline]")
                    console.print(f"     [dim green underline]https://www.google.com/maps/@?api=1&map_action=pano&viewpoint={float(alat):.5f},{float(alon):.5f}[/dim green underline]")
                except: pass
        console.print()
    console.print("[dim]  Yandex -> glisser-deposer la photo pour reverse image search[/dim]")
    console.print()

