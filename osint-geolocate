# ─── EXIF ────────────────────────────────────────────────────────────────────

def dms_to_decimal(dms, ref):
    try:
        d, m, s = float(dms[0]), float(dms[1]), float(dms[2])
        v = d + m / 60.0 + s / 3600.0
        return -v if ref in ("S", "W") else v
    except Exception:
        return None

def extract_exif(path):
    try:
        img = Image.open(path)
        exif_data = img._getexif()
        if not exif_data:
            return None, None, None
        gps_info, timestamp = {}, None
        for tag_id, value in exif_data.items():
            tag = TAGS.get(tag_id, tag_id)
            if tag == "GPSInfo":
                for k, v in value.items():
                    gps_info[GPSTAGS.get(k, k)] = v
            elif tag in ("DateTime", "DateTimeOriginal"):
                try: timestamp = datetime.strptime(value, "%Y:%m:%d %H:%M:%S")
                except: pass
        if not gps_info:
            return None, None, timestamp
        lat = dms_to_decimal(gps_info.get("GPSLatitude"), gps_info.get("GPSLatitudeRef", "N"))
        lon = dms_to_decimal(gps_info.get("GPSLongitude"), gps_info.get("GPSLongitudeRef", "E"))
        return lat, lon, timestamp
    except Exception as e:
        console.print(f"[yellow]EXIF error: {e}[/yellow]")
        return None, None, None

# ─── SOLAR ───────────────────────────────────────────────────────────────────

def solar_analysis(lat, lon, timestamp):
    try:
        import ephem
        obs = ephem.Observer()
        obs.lat, obs.lon = str(lat), str(lon)
        obs.date = (timestamp.astimezone(timezone.utc) if timestamp.tzinfo else timestamp).strftime("%Y/%m/%d %H:%M:%S")
        sun = ephem.Sun(obs)
        alt, az = math.degrees(float(sun.alt)), math.degrees(float(sun.az))
        if alt < 0:
            return f"Soleil sous l'horizon ({alt:.1f}°) — nuit/crépuscule"
        return f"Soleil à {alt:.1f}° altitude, azimut {az:.1f}°"
    except ImportError:
        return "ephem non installé"
    except Exception as e:
        return f"Calcul impossible ({e})"

# ─── NOMINATIM ───────────────────────────────────────────────────────────────

def nominatim_geocode(query):
    if not query or len(query.strip()) < 3:
        return None, None, None
    try:
        r = requests.get(
            "https://nominatim.openstreetmap.org/search",
            params={"q": query, "format": "json", "limit": 1},
            headers={"User-Agent": "osint-geolocate/2.0"},
            timeout=10
        )
        r.raise_for_status()
        res = r.json()
        if res:
            return float(res[0]["lat"]), float(res[0]["lon"]), res[0].get("display_name", query)
    except Exception:
        pass
    return None, None, None

def build_geocode_query(analysis):
    city    = (analysis.get("estimated_city") or "").strip()
    country = (analysis.get("estimated_country") or "").strip()
    region  = (analysis.get("estimated_region") or "").strip()
    lms     = analysis.get("landmarks", [])
    top_lm  = sorted(lms, key=lambda x: x.get("confidence", 0), reverse=True)[0].get("name", "").strip() if lms else ""
    if city and country:    return f"{city}, {country}"
    if top_lm and country:  return f"{top_lm}, {country}"
    if city:                return city
    if top_lm:              return top_lm
    if region and country:  return f"{region}, {country}"
    return country or region

