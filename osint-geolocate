@click.option("--picarta-key", envvar="PICARTA_API_KEY", default=None,
              help="Cle API Picarta (gratuit : picarta.ai, 10 credits)")
@click.option("--no-solar",   is_flag=True, default=False, help="Desactiver calcul solaire")
@click.option("--no-search",  is_flag=True, default=False, help="Desactiver recherche DDG")
@click.option("--ocr-model",  default=MODEL_OCR,  help="Modele OCR ollama")
@click.option("--geo-model",  default=MODEL_GEO,  help="Modele GEO ollama")
@click.option("--reas-model", default=MODEL_REAS, help="Modele RAISONNEMENT ollama")
def main(image, picarta_key, no_solar, no_search, ocr_model, geo_model, reas_model):
    """
    OSINT image geolocation v3 -- Pipeline multi-modeles + Picarta.

    \b
    Pipeline :
      EXIF -> Picarta -> OCR (qwen3.5) -> GEO (gemma4) -> RAISONNEMENT (kimi)
      -> Nominatim -> DDG -> Solar

    \b
    Cle Picarta gratuite (10 credits) : https://picarta.ai
    export PICARTA_API_KEY="votre_cle"

    \b
    Exemples:
      osint-geolocate photo.jpg
      osint-geolocate photo.jpg --picarta-key YOUR_KEY
      PICARTA_API_KEY=xxx osint-geolocate photo.jpg
    """
    global MODEL_OCR, MODEL_GEO, MODEL_REAS
    MODEL_OCR, MODEL_GEO, MODEL_REAS = ocr_model, geo_model, reas_model
    path = Path(image)
    console.print()
    console.print(Panel(
        f"[bold white]OSINT-GEOLOCATE v3[/bold white]  [dim]{path.name}[/dim]\n"
        f"[dim]OCR:{MODEL_OCR}  GEO:{MODEL_GEO}  RAIS:{MODEL_REAS}[/dim]",
        box=box.DOUBLE_EDGE, style="bright_blue", padding=(0,2)
    ))
    console.print()

    lat, lon, timestamp = extract_exif(path)
    if lat is not None and lon is not None:
        ps("EXIF", f"GPS trouve : {lat:.6f}, {lon:.6f}", "bright_cyan")
        if timestamp: ps("EXIF", f"Timestamp  : {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "bright_cyan")
        console.print()
        print_result(lat, lon, "Coordonnees EXIF", "GPS")
        return
    ps("EXIF", "Aucune donnee GPS", "yellow")
    if timestamp: ps("EXIF", f"Timestamp : {timestamp.strftime('%Y-%m-%d %H:%M:%S')}", "dim yellow")
    console.print()

    ocr, geo, reasoning, picarta_cands, nom_lat, nom_lon = run_pipeline(
        path, picarta_key=picarta_key, no_search=no_search
    )

    final_lat, final_lon, source = best_coords(reasoning, geo, picarta_cands, nom_lat, nom_lon)

    if not no_solar and timestamp and final_lat:
        ps("SOLAR", solar_analysis(final_lat, final_lon, timestamp), "magenta")
        console.print()

    alternatives = list(reasoning.get("alternative_locations", []) or [])
    for c in picarta_cands[1:4]:
        conf = c.get("confidence",0)
        conf_pct = int(conf*100) if conf<=1 else int(conf)
        alternatives.append({
            "label": f"{c.get('city','')}, {c.get('country','')}",
            "lat": c["lat"], "lon": c["lon"],
            "reason": f"Picarta ({conf_pct}%)",
        })

    city    = reasoning.get("final_city") or geo.get("estimated_city") or ""
    country = reasoning.get("final_country") or geo.get("estimated_country") or ""
    region  = reasoning.get("final_region") or geo.get("estimated_region") or ""
    label   = ", ".join(filter(None, [city, country or region])) or "Estimation IA"

    if final_lat is not None:
        print_result(final_lat, final_lon, label, source, alternatives=alternatives)
    else:
        console.print(Panel(
            "[yellow]Coordonnees non determinees.[/yellow]\n"
            f"[dim]Region estimee : {label or 'Inconnue'}[/dim]\n\n"
            "[white]-> Reverse image search :[/white]\n"
            "[yellow underline]https://yandex.com/images/search?rpt=imageview[/yellow underline]",
            box=box.ROUNDED, style="yellow"
        ))
        if alternatives:
            console.print(Rule("[dim]Positions candidates[/dim]", style="dim"))
            for i, a in enumerate(alternatives[:5], 1):
                alat, alon = a.get("lat"), a.get("lon")
                alabel = a.get("label") or f"{a.get('city','')}, {a.get('country','')}".strip(", ")
                console.print(f"  [bold cyan][{i}][/bold cyan] {alabel}")
                if a.get("reason"): console.print(f"     [dim]{a['reason'][:100]}[/dim]")
                if alat and alon:
                    try:
                        console.print(f"     [dim blue underline]https://maps.google.com/?q={float(alat):.5f},{float(alon):.5f}[/dim blue underline]")
                        console.print(f"     [dim green underline]https://www.google.com/maps/@?api=1&map_action=pano&viewpoint={float(alat):.5f},{float(alon):.5f}[/dim green underline]")
                    except: pass
        console.print()

if __name__ == "__main__":
    main()
