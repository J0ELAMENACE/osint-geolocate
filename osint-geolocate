def dms_to_decimal(dms, ref):
    try:
        d, m, s = float(dms[0]), float(dms[1]), float(dms[2])
        v = d + m / 60.0 + s / 3600.0
        return -v if ref in ("S", "W") else v
    except: return None

def extract_exif(path):
    try:
        img = Image.open(path)
        exif_data = img._getexif()
        if not exif_data: return None, None, None
        gps_info, timestamp = {}, None
        for tag_id, value in exif_data.items():
            tag = TAGS.get(tag_id, tag_id)
            if tag == "GPSInfo":
                for k, v in value.items(): gps_info[GPSTAGS.get(k, k)] = v
            elif tag in ("DateTime", "DateTimeOriginal"):
                try: timestamp = datetime.strptime(value, "%Y:%m:%d %H:%M:%S")
                except: pass
        if not gps_info: return None, None, timestamp
        lat = dms_to_decimal(gps_info.get("GPSLatitude"), gps_info.get("GPSLatitudeRef", "N"))
        lon = dms_to_decimal(gps_info.get("GPSLongitude"), gps_info.get("GPSLongitudeRef", "E"))
        return lat, lon, timestamp
    except Exception as e:
        console.print(f"[yellow]EXIF error: {e}[/yellow]")
        return None, None, None

def picarta_geolocate(path, api_token, top_k=5):
    try:
        with open(path, "rb") as f:
            b64 = base64.b64encode(f.read()).decode("utf-8")
        payload = {"TOKEN": api_token, "IMAGE": b64, "TOP_K": top_k}
        r = requests.post("https://picarta.ai/classify", json=payload,
                          headers={"Content-Type": "application/json"}, timeout=30)
        r.raise_for_status()
        data = r.json()
        candidates = []
        preds = data.get("topk_predictions_dict", {})
        for k in sorted(preds.keys(), key=lambda x: int(x)):
            p = preds[k]
            gps  = p.get("gps", [0, 0])
            addr = p.get("address", {})
            candidates.append({
                "lat":        float(gps[0]) if gps else 0,
                "lon":        float(gps[1]) if len(gps) > 1 else 0,
                "city":       addr.get("city", ""),
                "country":    addr.get("country", ""),
                "province":   addr.get("province", ""),
                "confidence": float(p.get("confidence", 0)),
                "source":     "Picarta",
            })
        return candidates
    except requests.exceptions.HTTPError as e:
        codes = {401: "cle invalide", 402: "credits epuises"}
        console.print(f"[yellow]Picarta : {codes.get(e.response.status_code, f'HTTP {e.response.status_code}')}[/yellow]")
        return []
    except Exception as e:
        console.print(f"[yellow]Picarta erreur : {e}[/yellow]")
        return []

def solar_analysis(lat, lon, timestamp):
    try:
        import ephem
        obs = ephem.Observer()
        obs.lat, obs.lon = str(lat), str(lon)
        obs.date = (timestamp.astimezone(timezone.utc) if timestamp.tzinfo else timestamp).strftime("%Y/%m/%d %H:%M:%S")
        sun = ephem.Sun(obs)
        alt, az = math.degrees(float(sun.alt)), math.degrees(float(sun.az))
        if alt < 0: return f"Soleil sous horizon ({alt:.1f}) - nuit"
        return f"Soleil a {alt:.1f} altitude, azimut {az:.1f}"
    except ImportError: return "ephem non installe"
    except Exception as e: return f"Calcul impossible ({e})"

def nominatim_geocode(query):
    if not query or len(query.strip()) < 3: return None, None, None
    try:
        r = requests.get("https://nominatim.openstreetmap.org/search",
                         params={"q": query, "format": "json", "limit": 1},
                         headers={"User-Agent": "osint-geolocate/3.0"}, timeout=10)
        r.raise_for_status()
        res = r.json()
        if res: return float(res[0]["lat"]), float(res[0]["lon"]), res[0].get("display_name", query)
    except: pass
    return None, None, None

def web_search(query, max_results=5):
    if not DDG_AVAILABLE: return []
    try:
        with DDGS() as ddgs: return list(ddgs.text(query, max_results=max_results))
    except: return []

def image_to_b64(path):
    with open(path, "rb") as f: return base64.b64encode(f.read()).decode()

def ollama_ping():
    try:
        r = requests.get("http://localhost:11434/api/tags", timeout=5)
        r.raise_for_status()
        return True
    except: return False

def ollama_call(model, prompt, b64=None, timeout=None):
    payload = {"model": model, "prompt": prompt, "stream": False, "options": {"temperature": 0.1}}
    if b64: payload["images"] = [b64]
    r = requests.post("http://localhost:11434/api/generate", json=payload, timeout=timeout or OLLAMA_TIMEOUT)
    r.raise_for_status()
    return r.json().get("response", "")

def parse_response(raw):
    clean = re.sub(r"```(?:json)?", "", raw).strip()
    m = re.search(r"\{.*\}", clean, re.DOTALL)
    if m:
        try: return json.loads(m.group())
        except: pass
    try: return json.loads(clean)
    except: return {"reasoning": raw}

